# =============================================================================
# OutreachOS — environment variables (copy to .env, never commit .env)
# =============================================================================
# Get values from: Supabase Dashboard → Project Settings → API
#
# Full setup guide: docs/DEVELOPER_SETUP.md
# =============================================================================

# Project URL (e.g. https://abcdefghijklmnop.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# anon / publishable key — safe for client apps with RLS enabled
# NEVER use the service_role key here
VITE_SUPABASE_ANON_KEY=your-anon-key-here
