{
  "name": "outreachos",
  "productName": "OutreachOS",
  "private": true,
  "version": "0.1.0",
  "description": "AI Sales CRM Desktop App",
  "author": "Conscious Automation",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.consciousautomation.outreachos",
    "productName": "OutreachOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "autoprefixer": "^10.5.0",
    "electron": "^41.6.1",
    "electron-auto-launch": "^5.0.7",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.16.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
